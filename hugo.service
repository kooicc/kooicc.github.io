[Unit]
Description=Hugo Static Site Generator
After=network.target

[Service]
ExecStart=hugo server -D --bind=0.0.0.0 --baseURL=http://172.16.31.170:1313 --port=1313 --appendPort=false --liveReloadPort=443
WorkingDirectory=/mnt/data/kooicc.github.io
User=root
Group=root
Restart=always
RestartSec=3
LimitNOFILE=8192

[Install]
WantedBy=multi-user.target
